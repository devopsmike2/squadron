# Binaries
bin/
dist/
*.exe
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Data directories — anchored to repo root so subdirs like
# ui/src/data/ don't get silently shadowed. See #606.
/data/
*.db
*.duckdb

# Go workspace file
go.work

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Node modules (for UI)
ui/node_modules/
ui/dist/
ui/.pnpm-store/
ui/package-lock.json
ui/coverage/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log

# Temporary files
tmp/
temp/

# Built binaries (always live in bin/ or cmd/*/<name>; never the repo root)
/all-in-one
/squadronctl
/fleetsim
/webhook-echo
/squadron-action-runner

# stray go build artifacts at repo root
/squadron-proposer-bench
